# Copy this file to .env and fill in your values

# Your E2B API key (get one at https://e2b.dev)
E2B_API_KEY=your_e2b_api_key_here

# Sandbox template to use:
#   lovable-template-dev  → for local/dev testing (build with pnpm e2b:build:dev)
#   lovable-template      → for production template testing
SANDBOX_TEMPLATE=lovable-template-dev

# Base path for the project inside the sandbox (default for e2b-template)
PROJECT_BASE_PATH=/home/user/project
